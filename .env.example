# LLM provider: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o

# Anthropic (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_MODEL=claude-opus-4-6

# Optional: kubeconfig path (defaults to ~/.kube/config)
# KUBECONFIG=/path/to/kubeconfig

# Optional: lock to a specific context (defaults to active context)
# KUBECONFIG_CONTEXT=my-context-name

# Optional: disable SSL verification (use if cluster CA is missing Authority Key Identifier)
# KUBECONFIG_INSECURE_SKIP_TLS_VERIFY=true

# Optional: GitHub token for searching issues related to errors (5000 req/hour with token, 60 without)
# GITHUB_TOKEN=your_github_token_here